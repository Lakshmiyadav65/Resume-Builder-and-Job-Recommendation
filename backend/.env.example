# ===========================================
# ATScribe Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas Connection
# Get your URI from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/atscribe?retryWrites=true&w=majority

# Groq API Key (for LLM-powered features)
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Frontend URL (for CORS in production)
FRONTEND_URL=https://your-app.vercel.app
