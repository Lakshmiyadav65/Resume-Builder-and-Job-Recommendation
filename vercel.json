{
    "version": 2,
    "builds": [
        {
            "src": "backend/server.js",
            "use": "@vercel/node"
        },
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "build"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "backend/server.js"
        },
        {
            "src": "/static/(.*)",
            "dest": "frontend/static/$1"
        },
        {
            "src": "/manifest.json",
            "dest": "frontend/manifest.json"
        },
        {
            "src": "/favicon.ico",
            "dest": "frontend/favicon.ico"
        },
        {
            "src": "/logo.png",
            "dest": "frontend/logo.png"
        },
        {
            "src": "/(.*\\.(js|css|ico|png|jpg|jpeg|svg|gif|webp|woff|woff2|ttf|eot|json|map))",
            "dest": "frontend/$1"
        },
        {
            "src": "/(.*)",
            "dest": "frontend/index.html"
        }
    ]
}
