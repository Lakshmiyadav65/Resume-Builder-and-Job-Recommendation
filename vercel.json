{
    "version": 2,
    "framework": null,
    "installCommand": "cd backend && npm install && cd ../frontend && npm install",
    "buildCommand": "cd frontend && CI=false npm run build",
    "outputDirectory": "frontend/build",
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "backend/server.js"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ],
    "functions": {
        "backend/server.js": {
            "includeFiles": "backend/**"
        }
    }
}
